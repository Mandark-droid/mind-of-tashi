# Mind of Tashi — environment template.
#
# Copy to `.env` (gitignored) and fill in real values. Only the keys you
# actually use need to be populated; the harness skips any teacher whose
# key is missing and the pool router will rotate around it.
#
# This file is checked into git; `.env` is NOT.

# --- Hugging Face -----------------------------------------------------------
# Used by:
#   - llama-cpp-python (Llama.from_pretrained pulls GGUF from the Hub)
#   - leaderboard.py / app.py (publish runs to the leaderboard dataset)
#   - the in-window SFT/GRPO trainer (push fine-tuned models)
# Scope: read for inference, write for leaderboard + model push.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Self-play teacher providers (used by tools/selfplay.py) ----------------
# Each free tier has its own daily limits. The pool router rotates across
# them automatically — see teachers/quota.py for defaults.

# Google Gemini — 50 req/day per model id.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — many free models, ~200 req/day each (varies).
# Used by tools/list_openrouter_free.py to auto-fetch the rotation pool.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral La Plateforme — free tier limited.
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Sarvam — Indian-language native, important for the bilingual
# EN+Hindi/Sanskrit mind-scroll register.
# https://www.sarvam.ai/
SARVAM_API_KEY=

# --- Live-gameplay capture (used by live_traces.py + push_live_to_hub.py) ---
# When set, every completed match from the running app.py gets pushed as a
# multi-turn SFT example to this private HF Dataset. Unset = local-only capture.
LIVE_TRACES_REPO=kshitijthakkar/mind-of-tashi-live-traces
# LIVE_TRACES_DISABLE=0     # 1 = bypass capture entirely (e.g. for debug runs)
# LIVE_TRACES_LOCAL_DIR=    # override the default ../data/live/ path

# --- Live-game model selection (read by llm.Reasoner) -----------------------
# Optional overrides. Defaults from llm.py:
#   MODEL_REPO=Qwen/Qwen3-4B-GGUF
#   MODEL_FILE=Qwen3-4B-Q4_K_M.gguf
# Set these to point at the in-window SFT/GRPO GGUF once it ships.
# MODEL_REPO=
# MODEL_FILE=
# MODEL_N_CTX=4096
# MODEL_N_THREADS=
# N_GPU_LAYERS=0          # 0 = CPU-only (the reliable Spaces path)
# FORCE_MOCK=0            # 1 = skip llama.cpp entirely, use the heuristic

# --- Leaderboard (set on the deployed Space, not usually locally) -----------
# LEADERBOARD_REPO=<owner>/mind-of-tashi-runs
# LEADERBOARD_DISABLE=0   # 1 = no-op even with HF_TOKEN present

# --- Ollama (optional, local) -----------------------------------------------
# Override only if Ollama is on a non-default host.
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Live self-play (selfplay_live.py) --------------------------------------
# When SELFPLAY_MODE=1, the running app.py replaces both sides of the duel
# with LLMs and the UI grows a "Watch self-play" button. live_traces capture
# is skipped in this mode (two-AI play, not real player data — use
# tools/selfplay.py for the SFT-bound synthetic harness).
#
# Spec strings go through teachers.make_teacher, so any backend works:
#   ollama:qwen3:4b, ollama:ministral-3:3b, ollama:deepseek-r1:1.5b,
#   gemini:gemini-2.5-flash, mistral:mistral-large-latest,
#   openrouter:<author>/<model>:free, mock, llamacpp
#
# 6 GB VRAM (RTX 3060) sweet spots — sequential calls let Ollama swap, so
# total VRAM use is roughly max(player, opponent), not the sum:
#   qwen3:4b (2.5GB) + ministral-3:3b (3.0GB)         <- the default below
#   qwen3:4b (2.5GB) + deepseek-r1:1.5b (1.1GB)       <- fastest, asymmetric
#   ministral-3:3b   + qwen3.5:4b (3.4GB)             <- best Hindi/Sanskrit
#   qwen3:0.6b       + lfm2.5-thinking:1.2b           <- tiny, very fast
# Avoid pairing two 4B+ models — works but Ollama will reload-swap each call.
SELFPLAY_MODE=0
SELFPLAY_PLAYER_TEACHER=ollama:qwen3:1.7b
SELFPLAY_OPPONENT_TEACHER=ollama:qwen3.5:4b
# Player persona to role-play. "mirror" = same as the current opponent (mirror
# match). Use a LADDER id (tashi/norbu/pema/drogpa/the-mountain) to pin.
SELFPLAY_PLAYER_PERSONA=mirror
